SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app-url.fly.dev
SCOPES=write_script_tags,read_script_tags,write_themes,read_themes,write_products,read_products,read_orders,write_orders

DATABASE_URL=postgresql://user:password@localhost:5432/speed_optimizer

REDIS_URL=redis://localhost:6379

GOOGLE_PAGESPEED_API_KEY=your_google_pagespeed_api_key

# Optional: Fly.io / Railway secrets are injected automatically
NODE_ENV=development
